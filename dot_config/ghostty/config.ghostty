# ref: https://ghostty.org/docs/config/reference

theme = Iceberg Dark

background-opacity = 0.8

window-padding-x = 12
window-padding-y = 8

auto-update = check
auto-update-channel = stable

cursor-style = bar
cursor-style-blink = false

split-divider-color = #3e4359
unfocused-split-opacity = 0.7

macos-option-as-alt = true
